{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/vercel_static/assets/$1"
    },
    {
      "src": "/static/(.*)",
      "dest": "/vercel_static/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/vercel_static/index.html"
    }
  ]
}