rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email in [
          "admin@example.com"
        ];
    }

    match /listeningParts/{part}/chunks/{chunk} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /listeningMeta/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
