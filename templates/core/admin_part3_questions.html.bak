{% load static %}
<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Quản lý Part 3 | Aptis Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <style>
        :root {
            --red: #e60023;
            --red2: #ff5f76;
            --deep: #3f0011;
            --soft: #fff1f4;
            --line: #ffd1dc;
            --muted: #667085;
            --card: rgba(255,255,255,.94);
            --shadow: 0 24px 60px rgba(170,0,35,.12);
        }

        * { box-sizing: border-box; }

        body {
            margin: 0;
            padding: 24px;
            min-height: 100vh;
            font-family: Georgia, "Times New Roman", serif;
            background:
                radial-gradient(circle at top right, rgba(255,95,118,.18), transparent 34%),
                linear-gradient(135deg, #fffafa, #ffecef);
            color: var(--deep);
        }

        a { color: inherit; text-decoration: none; }

        .page {
            max-width: 1420px;
            margin: 0 auto;
        }

        .hero {
            display: flex;
            justify-content: space-between;
            gap: 18px;
            align-items: center;
            padding: 26px 30px;
            margin-bottom: 20px;
            border: 1px solid var(--line);
            border-radius: 30px;
            background:
                radial-gradient(circle at top right, rgba(255,95,118,.16), transparent 35%),
                rgba(255,255,255,.9);
            box-shadow: var(--shadow);
        }

        .badge {
            display: inline-flex;
            padding: 8px 13px;
            border-radius: 999px;
            background: var(--soft);
            color: var(--red);
            font-size: 13px;
            font-weight: 950;
            text-transform: uppercase;
            letter-spacing: .08em;
        }

        h1 {
            margin: 12px 0 8px;
            font-size: clamp(34px, 4vw, 56px);
            line-height: 1.02;
            letter-spacing: -.055em;
        }

        .lead {
            margin: 0;
            max-width: 780px;
            color: var(--muted);
            font-size: 17px;
            line-height: 1.6;
            font-weight: 700;
        }

        .btn {
            border: 0;
            border-radius: 999px;
            padding: 13px 18px;
            font-family: inherit;
            font-size: 15px;
            font-weight: 950;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: .18s ease;
            white-space: nowrap;
        }

        .btn:hover { transform: translateY(-2px); }

        .btn.primary {
            color: white;
            background: linear-gradient(135deg, var(--red), var(--red2));
            box-shadow: 0 16px 34px rgba(230,0,35,.22);
        }

        .btn.light {
            color: #8a0015;
            background: white;
            border: 1px solid var(--line);
        }

        .btn.danger {
            color: white;
            background: #9f1239;
        }

        .grid {
            display: grid;
            grid-template-columns: 320px 1fr;
            gap: 20px;
        }

        .panel {
            border: 1px solid var(--line);
            border-radius: 28px;
            background: var(--card);
            box-shadow: var(--shadow);
            overflow: hidden;
        }

        .panel-head {
            padding: 20px 22px;
            border-bottom: 1px solid var(--line);
            background: linear-gradient(180deg, #fff, #fff7f9);
        }

        .panel-title {
            margin: 0;
            font-size: 23px;
            letter-spacing: -.035em;
        }

        .panel-note {
            margin: 6px 0 0;
            color: var(--muted);
            font-size: 14px;
            font-weight: 700;
        }

        .panel-body { padding: 20px; }

        .material-list {
            display: grid;
            gap: 10px;
        }

        .material-link {
            display: block;
            padding: 14px 15px;
            border: 1px solid var(--line);
            border-radius: 18px;
            background: #fffafa;
            transition: .18s ease;
        }

        .material-link:hover,
        .material-link.active {
            border-color: #ff8da0;
            background: var(--soft);
        }

        .material-link strong {
            display: block;
            color: #620013;
            font-size: 15px;
            line-height: 1.35;
        }

        .material-link span {
            display: block;
            margin-top: 5px;
            color: var(--muted);
            font-size: 13px;
            font-weight: 700;
        }

        .form-grid {
            display: grid;
            gap: 15px;
        }

        .two {
            display: grid;
            grid-template-columns: 1fr 180px;
            gap: 14px;
        }

        label {
            display: block;
            margin-bottom: 7px;
            color: #720014;
            font-size: 14px;
            font-weight: 950;
        }

        input, textarea, select {
            width: 100%;
            border: 1px solid var(--line);
            border-radius: 16px;
            background: #fffafa;
            color: var(--deep);
            outline: none;
            font-family: inherit;
            font-size: 15px;
            padding: 13px 14px;
        }

        textarea {
            min-height: 105px;
            resize: vertical;
            line-height: 1.55;
        }

        input:focus, textarea:focus, select:focus {
            border-color: #ff8195;
            background: white;
            box-shadow: 0 0 0 5px rgba(255,95,118,.12);
        }

        .Câu hỏi-card {
            padding: 16px;
            border: 1px solid var(--line);
            border-radius: 22px;
            background:
                radial-gradient(circle at top right, rgba(255,95,118,.10), transparent 35%),
                #fffafa;
        }

        .q-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 14px;
            margin-bottom: 12px;
        }

        .q-number {
            width: 38px;
            height: 38px;
            display: grid;
            place-items: center;
            border-radius: 14px;
            background: linear-gradient(135deg, var(--red), var(--red2));
            color: white;
            font-weight: 950;
        }

        .q-title {
            margin: 0;
            font-size: 18px;
            color: #5b0010;
        }

        .options {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            margin-top: 12px;
        }

        .messages {
            margin-bottom: 16px;
            display: grid;
            gap: 10px;
        }

        .message {
            padding: 13px 15px;
            border-radius: 16px;
            background: var(--soft);
            color: #7a0015;
            border: 1px solid var(--line);
            font-weight: 850;
        }

        .empty {
            padding: 22px;
            border-radius: 22px;
            background: #fffafa;
            border: 1px dashed #ff9aaa;
            color: var(--muted);
            font-weight: 800;
            line-height: 1.55;
        }

        @media (max-width: 980px) {
            body { padding: 16px; }
            .hero { display: block; }
            .hero .actions { margin-top: 16px; }
            .grid { grid-template-columns: 1fr; }
            .two, .options { grid-template-columns: 1fr; }
        }
    </style>
</head>

<body>
<main class="page">
    <section class="hero">
        <div>
            <div class="badge">Listening Part 3</div>
            <h1>Quản lý Part 3</h1>
            <p class="lead">Tạo bộ câu hỏi Part 3 thật cho học viên: chủ đề, link audio, hướng dẫn, 4 nhận định, nhãn đáp án, đáp án đúng và transcript.</p>
        </div>

        <div class="actions">
            <a class="btn light" href="/dashboard/listening-parts/">← Quay lại danh sách Part</a>
            <a class="btn light" href="/listening/part-3/" target="_blank">Xem giao diện học viên</a>
        </div>
    </section>

    {% if messages %}
    <div class="messages">
        {% for message in messages %}
            <div class="message">{{ message }}</div>
        {% endfor %}
    </div>
    {% endif %}

    <section class="grid">
        <aside class="panel">
            <div class="panel-head">
                <h2 class="panel-title">Danh sách bộ Part 3</h2>
                <p class="panel-note">{{ materials|length }} bộ hiện có</p>
            </div>

            <div class="panel-body">
                <form method="post" style="margin-bottom:14px;">
                    {% csrf_token %}
                    <input type="hidden" name="action" value="create_material">
                    <button class="btn primary" type="submit" style="width:100%;">+ Tạo bộ mới</button>
                </form>

                <div class="material-list">
                    {% for item in materials %}
                        <a class="material-link {% if selected and item.id == selected.id %}active{% endif %}" href="?material_id={{ item.id }}">
                            <strong>{{ item.title }}</strong>
                            <span>{{ item.questions.count }} câu hỏi · {% if item.is_active %}Hiển thị{% else %}Ẩn{% endif %}</span>
                        </a>
                    {% empty %}
                        <div class="empty">Chưa có bộ Part 3 nào. Bấm Tạo bộ mới để bắt đầu.</div>
                    {% endfor %}
                </div>
            </div>
        </aside>

        <section class="panel">
            <div class="panel-head">
                <h2 class="panel-title">{% if selected %}Chỉnh sửa bộ câu hỏi{% else %}Chưa chọn bộ câu hỏi{% endif %}</h2>
                <p class="panel-note">Nội dung chỉnh sửa ở đây sẽ hiển thị trên trang Part 3 của học viên.</p>
            </div>

            <div class="panel-body">
                {% if selected %}
                <form method="post" class="form-grid">
                    {% csrf_token %}
                    <input type="hidden" name="action" value="save_material">
                    <input type="hidden" name="material_id" value="{{ selected.id }}">

                    <div class="two">
                        <div>
                            <label>Tên chủ đề</label>
                            <input name="title" value="{{ selected.title }}" placeholder="Topic: Changes in the workplace">
                        </div>

                        <div>
                            <label>Trạng thái</label>
                            <select name="is_active">
                                <option value="1" {% if selected.is_active %}selected{% endif %}>Hiển thị</option>
                                <option value="0" {% if not selected.is_active %}selected{% endif %}>Ẩn</option>
                            </select>
                        </div>
                    </div>

                    <div>
                        <label>Link audio</label>
                        <input name="audio_url" value="{{ selected.audio_url }}" placeholder="Paste audio link here">
                    </div>

                    <div>
                        <label>Hướng dẫn làm bài</label>
                        <textarea name="instructions">{{ selected.instructions }}</textarea>
                    </div>

                    {% for q in questions %}
                    <article class="question-card">
                        <input type="hidden" name="question_id" value="{{ q.id }}">

                        <div class="q-head">
                            <div style="display:flex; align-items:center; gap:12px;">
                                <div class="q-number">{{ forloop.counter }}</div>
                                <h3 class="q-title">Nhận định {{ forloop.counter }}</h3>
                            </div>

                            <div style="max-width:160px;">
                                <select name="correct_answer_{{ q.id }}">
                                    <option value="A" {% if q.correct_answer == "A" %}selected{% endif %}>Người nam</option>
                                    <option value="B" {% if q.correct_answer == "B" %}selected{% endif %}>Người nữ</option>
                                    <option value="C" {% if q.correct_answer == "C" %}selected{% endif %}>Cả hai</option>
                                </select>
                            </div>
                        </div>

                        <label>Nhận định text</label>
                        <textarea name="Câu hỏi_text_{{ q.id }}" style="min-height:74px;">{{ q.Câu hỏi_text }}</textarea>

                        <div class="options">
                            <div>
                                <label>Nhãn đáp án A</label>
                                <input name="option_a_{{ q.id }}" value="{{ q.option_a|default:'Người nam' }}">
                            </div>

                            <div>
                                <label>Nhãn đáp án B</label>
                                <input name="option_b_{{ q.id }}" value="{{ q.option_b|default:'Người nữ' }}">
                            </div>

                            <div>
                                <label>Nhãn đáp án C</label>
                                <input name="option_c_{{ q.id }}" value="{{ q.option_c|default:'Cả hai' }}">
                            </div>
                        </div>

                        <label style="margin-top:12px;">Giải thích / ghi chú</label>
                        <textarea name="explanation_{{ q.id }}" style="min-height:70px;">{{ q.explanation }}</textarea>
                    </article>
                    {% endfor %}

                    <div>
                        <label>Transcript / đoạn văn</label>
                        <textarea name="transcript" style="min-height:150px;">{{ selected.transcript }}</textarea>
                    </div>

                    <div style="display:flex; gap:12px; flex-wrap:wrap;">
                        <button class="btn primary" type="submit">Lưu bộ Part 3</button>
                        <button class="btn danger" type="submit" name="action" value="delete_material" onclick="return confirm('Xóa bộ Part 3 này?')">Xóa bộ này</button>
                    </div>
                </form>
                {% else %}
                    <div class="empty">Hãy tạo hoặc chọn một bộ Part 3 ở cột bên trái.</div>
                {% endif %}
            </div>
        </section>
    </section>
</main>
<style id="aptis-part3-topic-builder-style">
  .aptis-p3-topic-card {
    width: 100%;
    border: 1px solid rgba(255, 42, 79, .22);
    background: linear-gradient(135deg, #fff, #fff5f7);
    border-radius: 18px;
    padding: 14px 16px;
    margin-top: 12px;
    cursor: pointer;
    text-align: left;
    box-shadow: 0 10px 28px rgba(255, 42, 79, .08);
    transition: .18s ease;
  }

  .aptis-p3-topic-card:hover,
  .aptis-p3-topic-card.is-active {
    transform: translateY(-1px);
    border-color: rgba(255, 42, 79, .65);
    box-shadow: 0 16px 36px rgba(255, 42, 79, .14);
  }

  .aptis-p3-topic-name {
    display: block;
    color: #5b0018;
    font-size: 15px;
    font-weight: 900;
    line-height: 1.25;
  }

  .aptis-p3-topic-meta {
    display: block;
    margin-top: 4px;
    color: #8b6670;
    font-size: 12px;
    font-weight: 700;
  }

  .aptis-p3-editor {
    width: 100%;
    overflow-x: auto;
  }

  .aptis-p3-editor-grid {
    min-width: 980px;
    display: grid;
    grid-template-columns: 1fr 1.25fr repeat(4, 1fr) 1.3fr 1.3fr;
    gap: 12px;
    align-items: stretch;
  }

  .aptis-p3-panel {
    border: 1px solid rgba(255, 42, 79, .18);
    background: rgba(255, 255, 255, .92);
    border-radius: 18px;
    padding: 14px;
    min-height: 230px;
    box-shadow: 0 10px 28px rgba(91, 0, 24, .05);
  }

  .aptis-p3-panel h4 {
    margin: 0 0 12px;
    color: #ff1744;
    font-size: 14px;
    font-weight: 950;
  }

  .aptis-p3-panel input,
  .aptis-p3-panel textarea {
    width: 100%;
    border: 1px solid rgba(255, 42, 79, .22);
    border-radius: 14px;
    background: #fff;
    color: #5b0018;
    outline: none;
    padding: 11px 12px;
    font-weight: 700;
    font-size: 13px;
  }

  .aptis-p3-panel textarea {
    min-height: 150px;
    resize: vertical;
    line-height: 1.45;
  }

  .aptis-p3-speaker-note {
    grid-column: 3 / 7;
    border: 2px dashed rgba(255, 42, 79, .28);
    border-radius: 18px;
    background: linear-gradient(135deg, rgba(255, 245, 247, .95), rgba(255, 255, 255, .95));
    color: #ff1744;
    font-size: 16px;
    font-weight: 900;
    text-align: center;
    padding: 22px 18px;
  }

  .aptis-p3-actions {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
    margin-top: 16px;
  }

  .aptis-p3-btn {
    border: 0;
    border-radius: 999px;
    padding: 12px 20px;
    color: #fff;
    background: linear-gradient(135deg, #ff003d, #ff5570);
    font-weight: 950;
    cursor: pointer;
    box-shadow: 0 14px 26px rgba(255, 0, 61, .18);
  }

  .aptis-p3-btn.secondary {
    color: #a00028;
    background: #fff;
    border: 1px solid rgba(255, 42, 79, .25);
    box-shadow: none;
  }

  .aptis-p3-small-title {
    margin: 0 0 8px;
    color: #5b0018;
    font-size: 20px;
    font-weight: 950;
  }

  .aptis-p3-small-subtitle {
    margin: 0 0 18px;
    color: #7d6870;
    font-size: 13px;
    font-weight: 700;
  }
</style>

<script id="aptis-part3-topic-builder-script">
(function () {
  const STORAGE_KEY = "aptis_listening_part3_topic_sets_v1";
  let currentId = null;

  const readSets = () => {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || "[]"); }
    catch { return []; }
  };

  const writeSets = (sets) => {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(sets));
  };

  const textOf = (el) => (el && el.textContent ? el.textContent.trim() : "");

  const findByText = (selector, words) => {
    return Array.from(document.querySelectorAll(selector)).find(el =>
      words.some(w => textOf(el).toLowerCase().includes(w.toLowerCase()))
    );
  };

  const findLeftBox = () => {
    const title = findByText("h1,h2,h3,h4,strong,div,p,span", ["Danh sách bộ Part 3", "Danh sách bộ Part 3"]);
    return title ? (title.closest("aside,section,div") || title.parentElement) : null;
  };

  const findMainBox = () => {
    const title = findByText("h1,h2,h3,h4,strong,div,p,span", ["Chưa chọn bộ câu hỏi", "No Câu hỏi set selected"]);
    return title ? (title.closest("section,main,div") || title.parentElement) : null;
  };

  const escapeHtml = (value) => String(value || "")
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#039;");

  const createSet = () => {
    const topic = prompt("Nhập tên chủ đề:");
    if (!topic || !topic.trim()) return;

    const sets = readSets();
    const item = {
      id: "p3_" + Date.now(),
      topic: topic.trim(),
      audioUrl: "",
      Câu hỏi: "",
      speakers: { A: "", B: "", C: "", D: "" },
      answerSet: "",
      voiceContent: "",
      createdAt: new Date().toISOString()
    };

    sets.unshift(item);
    writeSets(sets);
    currentId = item.id;
    renderAll();
  };

  const updateCurrent = (patch) => {
    const sets = readSets();
    const index = sets.findIndex(x => x.id === currentId);
    if (index < 0) return;
    sets[index] = { ...sets[index], ...patch };
    writeSets(sets);
    renderList();
  };

  const updateSpeaker = (speaker, value) => {
    const sets = readSets();
    const index = sets.findIndex(x => x.id === currentId);
    if (index < 0) return;
    sets[index].speakers = { ...(sets[index].speakers || {}), [speaker]: value };
    writeSets(sets);
  };

  const renderList = () => {
    const leftBox = findLeftBox();
    if (!leftBox) return;

    leftBox.querySelectorAll(".aptis-p3-topic-card").forEach(el => el.remove());

    const sets = readSets();
    const emptyText = findByText("p,div,span", ["Chưa có bộ Part 3", "Chưa có bộ Part 3"]);
    if (emptyText) emptyText.style.display = sets.length ? "none" : "";

    const anchor = findByText("button,a", ["Tạo bộ mới", "Tạo bộ mới"]);
    const place = anchor ? anchor.parentElement : leftBox;

    sets.forEach((item, i) => {
      const btn = document.createElement("button");
      btn.type = "button";
      btn.className = "aptis-p3-topic-card" + (item.id === currentId ? " is-active" : "");
      btn.innerHTML = `
        <span class="aptis-p3-topic-name">${escapeHtml(item.topic)}</span>
        <span class="aptis-p3-topic-meta">Chủ đề ${i + 1} · Bấm để chỉnh sửa</span>
      `;
      btn.addEventListener("click", () => {
        currentId = item.id;
        renderAll();
      });
      place.insertAdjacentElement("afterend", btn);
    });
  };

  const renderEditor = () => {
    const mainBox = findMainBox();
    if (!mainBox) return;

    const sets = readSets();
    const item = sets.find(x => x.id === currentId);

    if (!item) {
      mainBox.innerHTML = `
        <h3>Chưa chọn bộ câu hỏi</h3>
        <p>Nội dung chỉnh sửa ở đây sẽ hiển thị trên trang Part 3 của học viên.</p>
        <div style="border:1px dashed rgba(255,42,79,.25);border-radius:18px;padding:22px;margin-top:18px;color:#7d6870;font-weight:800;">
          Hãy tạo hoặc chọn một bộ Part 3 ở cột bên trái.
        </div>
      `;
      return;
    }

    mainBox.innerHTML = `
      <div class="aptis-p3-editor">
        <h3 class="aptis-p3-small-title">${escapeHtml(item.topic)}</h3>
        <p class="aptis-p3-small-subtitle">Tạo đầy đủ bộ câu hỏi Listening Part 3 cho học viên.</p>

        <div class="aptis-p3-editor-grid">
          <div class="aptis-p3-panel">
            <h4>URL audio / File MP3</h4>
            <input data-p3-field="audioUrl" value="${escapeHtml(item.audioUrl || "")}" placeholder="Dán URL file MP3 vào đây">
          </div>

          <div class="aptis-p3-panel">
            <h4>Câu hỏi</h4>
            <textarea data-p3-field="Câu hỏi" placeholder="Enter the main Câu hỏi">${escapeHtml(item.Câu hỏi || "")}</textarea>
          </div>

          ${["A", "B", "C", "D"].map(s => `
            <div class="aptis-p3-panel">
              <h4>Người nói ${s}</h4>
              <textarea data-p3-speaker="${s}" placeholder="Content for Người nói ${s}">${escapeHtml((item.speakers || {})[s] || "")}</textarea>
            </div>
          `).join("")}

          <div class="aptis-p3-panel">
            <h4>Bộ dữ liệu đáp án</h4>
            <textarea data-p3-field="answerSet" placeholder="Enter answer options / correct Bộ dữ liệu đáp án">${escapeHtml(item.answerSet || "")}</textarea>
          </div>

          <div class="aptis-p3-panel">
            <h4>Nội dung voice</h4>
            <textarea data-p3-field="voiceContent" placeholder="Enter transcript / Nội dung voice">${escapeHtml(item.voiceContent || "")}</textarea>
          </div>

          <div class="aptis-p3-speaker-note">
            All 4 speakers choose from the Bộ dữ liệu đáp án.
            <br>
            <span style="font-size:13px;color:#a66a78;">Lưu ý: giữ nhãn đáp án thống nhất cho học viên.</span>
          </div>
        </div>

        <div class="aptis-p3-actions">
          <button type="button" class="aptis-p3-btn secondary" data-p3-delete>Xóa chủ đề</button>
          <button type="button" class="aptis-p3-btn" data-p3-save>Lưu tạm</button>
        </div>
      </div>
    `;

    mainBox.querySelectorAll("[data-p3-field]").forEach(input => {
      input.addEventListener("input", () => updateCurrent({ [input.dataset.p3Field]: input.value }));
    });

    mainBox.querySelectorAll("[data-p3-speaker]").forEach(input => {
      input.addEventListener("input", () => updateSpeaker(input.dataset.p3Speaker, input.value));
    });

    mainBox.querySelector("[data-p3-save]")?.addEventListener("click", () => alert("Đã lưu tạm trên trình duyệt."));

    mainBox.querySelector("[data-p3-delete]")?.addEventListener("click", () => {
      if (!confirm("Xóa chủ đề này?")) return;
      const next = readSets().filter(x => x.id !== currentId);
      writeSets(next);
      currentId = next[0] ? next[0].id : null;
      renderAll();
    });
  };

  const renderAll = () => {
    renderList();
    renderEditor();
  };

  const bindCreateButtons = () => {
    Array.from(document.querySelectorAll("button,a")).forEach(btn => {
      const label = textOf(btn);
      if (label.includes("Tạo bộ mới") || label.toLowerCase().includes("Tạo bộ mới")) {
        if (btn.dataset.p3Bound === "1") return;
        btn.dataset.p3Bound = "1";
        btn.addEventListener("click", function (e) {
          e.preventDefault();
          createSet();
        });
      }
    });
  };

  document.addEventListener("DOMContentLoaded", () => {
    const sets = readSets();
    currentId = sets[0] ? sets[0].id : null;
    bindCreateButtons();
    renderAll();
  });

  setTimeout(() => {
    bindCreateButtons();
    renderAll();
  }, 600);
})();
</script>
</body>
</html>




