                    <div class="preview-frame">
                        <div class="audio-player">
                            <div class="play-dot">?</div>
                            <div>
                                <strong>Audio Part 3</strong>
                                <div style="font-size:13px; opacity:.8;">Minimal player preview</div>
                            </div>
                            <div class="audio-line"><span></span></div>
                        </div>

                        <div class="student-card">
                            <h2 id="previewTitle">Part 3 Listening Practice</h2>
                            <p id="previewInstruction" style="color:#64748B;font-weight:650;">
                                Listen to the audio and choose who each statement refers to.
                            </p>

                            <div class="question-card">
                                <div class="question-number">1</div>
                                <div class="statement">The speaker wants to change the plan.</div>
                                <select class="answer-select">
                                    <option>Ch?n ??p ?n</option>
                                    <option>M - Man</option>
                                    <option>W - Woman</option>
                                    <option>B - Both</option>
                                </select>
                            </div>
                        </div>
                    </div>
