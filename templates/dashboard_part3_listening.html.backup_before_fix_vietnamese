                <div style="margin-top:18px;">
                    <a class="part3-btn" href="/dashboard/">? Quay l?i Dashboard</a>
                    <a class="part3-btn primary" href="/part-3/">Xem giao di?n h?c vi?n</a>
                </div>
            </section>

            <section class="admin-grid">
                <div class="form-stack">
                    <article class="admin-card">
                        <h2>1. C?u h?nh b?i h?c</h2>
                        <div class="form-stack">
                            <div class="field">
                                <label>Title</label>
