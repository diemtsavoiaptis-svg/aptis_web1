                                    K?o th? audio v?o ??y ho?c b?m ?? ch?n file MP3/WAV
                                </div>
                            </div>
                        </div>
                    </article>

                    <article class="admin-card">
                        <h2>2. Pool ??p ?n m?u</h2>
                        <div class="answer-pool">
                            <div class="pool-pill">M = Man</div>
                            <div class="pool-pill">W = Woman</div>
                            <div class="pool-pill">B = Both</div>
                        </div>
                    </article>

                    <article class="admin-card">
                        <h2>3. Question Builder</h2>
                        <div class="form-stack" id="questionBuilder">
                            <div class="question-row">
                                <div class="q-no">1</div>
                                <div class="field">
                                    <label>Statement</label>
                                    <input value="The speaker wants to change the plan.">
                                </div>
                                <div class="field">
                                    <label>Correct Answer</label>
                                    <select>
                                        <option value="M">M - Man</option>
                                        <option value="W">W - Woman</option>
                                        <option value="B">B - Both</option>
                                    </select>
                                </div>
                            </div>

                            <div class="question-row">
                                <div class="q-no">2</div>
                                <div class="field">
                                    <label>Statement</label>
                                    <input value="The speaker agrees with the suggestion.">
                                </div>
                                <div class="field">
                                    <label>Correct Answer</label>
                                    <select>
                                        <option value="M">M - Man</option>
                                        <option value="W" selected>W - Woman</option>
                                        <option value="B">B - Both</option>
                                    </select>
                                </div>
                            </div>

                            <div class="question-row">
                                <div class="q-no">3</div>
                                <div class="field">
                                    <label>Statement</label>
                                    <input value="They both mention the same problem.">
                                </div>
                                <div class="field">
                                    <label>Correct Answer</label>
                                    <select>
