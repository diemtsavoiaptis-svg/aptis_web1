                <pre>{
  "part": 3,
  "type": "listening_dropdown",
  "answer_pool": ["M", "W", "B"],
  "questions": [
    {"order": 1, "statement": "...", "correct_answer": "M"}
  ]
}</pre>
            </section>
        </div>
    </main>

    <script>
        const title = document.getElementById("lessonTitle");
        const instruction = document.getElementById("lessonInstruction");
        const previewTitle = document.getElementById("previewTitle");
        const previewInstruction = document.getElementById("previewInstruction");

        title.addEventListener("input", () => previewTitle.textContent = title.value || "Part 3 Listening Practice");
        instruction.addEventListener("input", () => previewInstruction.textContent = instruction.value || "Listen and choose.");
    </script>
</body>
</html>
